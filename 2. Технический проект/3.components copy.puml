@startuml Диаграмма компонентов
title "Компоненты сервиса обмена валют"

package "Currency Exchange Service" {
    [CurrencyExchangeController] <<Controller>> 
    [CurrencyExchangeProcessor] <<Component>> 
    [ExchangeRateFetcher] <<Component>> 
    [TransactionLogger] <<Component>> 
    [NotificationSender] <<Component>> 
}

package "External Systems" {
    [ExchangeRateAPI] <<External System>> 
    [PaymentGateway] <<External System>> 
    [NotificationService] <<External System>> 
}

package "Database" {
    [UserAccountsDB] <<Database>> 
    [TransactionsDB] <<Database>> 
}

package "Event Bus" {
    [EventBus] <<Event Bus>> 
}

' Взаимодействия
[CurrencyExchangeController] --> [CurrencyExchangeProcessor] : "Запрос на обмен валюты"
[CurrencyExchangeProcessor] --> [ExchangeRateFetcher] : "Получение актуальных курсов"
[ExchangeRateFetcher] --> [ExchangeRateAPI] : "Запрос курсов валют"
[CurrencyExchangeProcessor] --> [TransactionLogger] : "Логирование транзакции"
[TransactionLogger] --> [TransactionsDB] : "Запись данных транзакции"
[CurrencyExchangeProcessor] --> [PaymentGateway] : "Обработка платежа"
[CurrencyExchangeProcessor] --> [NotificationSender] : "Отправка уведомления"
[NotificationSender] --> [NotificationService] : "Уведомление пользователя"
[CurrencyExchangeProcessor] ---> [EventBus] : "Публикация события обмена валюты"

' Взаимодействие с базой данных
[CurrencyExchangeProcessor] --> [UserAccountsDB] : "Проверка и обновление баланса"

@enduml